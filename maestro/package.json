{
  "name": "maestro",
  "version": "0.1.0",
  "private": true,
  "description": "Local control plane for AI-assisted project orchestration.",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "node scripts/workspace.mjs build",
    "build:web": "node node_modules/typescript/bin/tsc -p apps/web/tsconfig.json && node apps/web/scripts/copy-static.mjs",
    "clean": "node scripts/workspace.mjs clean",
    "dev:server": "node apps/server/dist/index.js",
    "dev:web": "node apps/web/scripts/dev-server.mjs",
    "dev:ui": "node scripts/dev-ui.mjs",
    "maestro": "node apps/cli/dist/index.js",
    "typecheck": "node scripts/workspace.mjs typecheck",
    "typecheck:web": "node node_modules/typescript/bin/tsc -p apps/web/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
